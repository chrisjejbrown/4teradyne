{
  "$schema": "https://ns.adobe.com/aem/cf-model/1.0",
  "title": "Product Category",
  "description": "Defense & Aerospace product category for the product explorer (maps to WP taxonomy product_finder_cat)",
  "modelPath": "/conf/4teradyne/settings/dam/cfm/models/product-category",
  "fields": [
    {
      "id": "name",
      "type": "text",
      "required": true,
      "label": "Category Name",
      "description": "Display name of the product category",
      "placeholder": "e.g., Serial Bus Test",
      "examples": [
        "Analog Test",
        "Configurable Test Systems",
        "Optical Test",
        "Parallel Digital Test",
        "Serial Bus Test",
        "Switching"
      ]
    },
    {
      "id": "slug",
      "type": "text",
      "required": true,
      "label": "Slug",
      "description": "URL-safe identifier (kebab-case)",
      "validation": {
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "examples": [
        "analog-test",
        "configurable-test-systems",
        "serial-bus-test"
      ]
    },
    {
      "id": "sortOrder",
      "type": "number",
      "required": false,
      "label": "Sort Order",
      "description": "Display order in the category tabs (lower = first)"
    },
    {
      "id": "visibleFilters",
      "type": "text",
      "multi": true,
      "required": true,
      "label": "Visible Filters",
      "description": "Which filter columns to show when this category is active. Order determines column order in the UI.",
      "examples": [
        "platform",
        "physicalInterface",
        "numberOfChannels",
        "supportedBus",
        "testApplications",
        "swDefined",
        "ce",
        "function",
        "resolution",
        "analogBandwidth",
        "sampleRate"
      ]
    }
  ]
}
