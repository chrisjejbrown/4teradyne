<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="cq:Template"
          jcr:title="Product Category"
          jcr:description="Defense &amp; Aerospace product category for the product explorer"
          ranking="{Long}200"
          status="enabled">
    <jcr:content
        jcr:primaryType="nt:unstructured"
        jcr:title="Product Category"
        dataTypesConfig="/mnt/overlay/settings/dam/cfm/models/formbuilderconfig/datatypes"
        formModelPath="dam/cfm/models/editor/components/aemform">
        <items jcr:primaryType="nt:unstructured">

            <name jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Category Name"
                fieldDescription="Display name (e.g., Serial Bus Test)"
                name="name"
                required="{Boolean}true"
                renderType="textfield"
                valueType="string"/>

            <slug jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Slug"
                fieldDescription="URL-safe identifier (e.g., serial-bus-test)"
                name="slug"
                required="{Boolean}true"
                renderType="textfield"
                valueType="string"/>

            <sortOrder jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/numberfield"
                fieldLabel="Sort Order"
                fieldDescription="Display order in category tabs (lower = first)"
                name="sortOrder"
                required="{Boolean}false"
                renderType="numberfield"
                valueType="long"
                defaultValue="0"/>

            <visibleFilters jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Visible Filters"
                fieldDescription="Filter column names to show when this category is active"
                name="visibleFilters"
                required="{Boolean}true"
                renderType="textfield"
                multi="{Boolean}true"
                valueType="string[]"/>

        </items>
    </jcr:content>
</jcr:root>
