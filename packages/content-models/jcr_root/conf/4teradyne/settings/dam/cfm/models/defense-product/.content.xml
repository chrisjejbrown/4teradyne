<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="cq:Template"
          jcr:title="Defense &amp; Aerospace Product"
          jcr:description="Product entry for the Defense &amp; Aerospace Product Explorer"
          ranking="{Long}100"
          status="enabled">
    <jcr:content
        jcr:primaryType="nt:unstructured"
        jcr:title="Defense &amp; Aerospace Product"
        dataTypesConfig="/mnt/overlay/settings/dam/cfm/models/formbuilderconfig/datatypes"
        formModelPath="dam/cfm/models/editor/components/aemform">
        <items jcr:primaryType="nt:unstructured">

            <productModel jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Model Number"
                fieldDescription="Short model identifier (e.g., PXIe-25G, Guardian)"
                name="productModel"
                required="{Boolean}true"
                renderType="textfield"
                valueType="string"/>

            <productName jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Product Name"
                fieldDescription="Descriptive name without model prefix"
                name="productName"
                required="{Boolean}true"
                renderType="textfield"
                valueType="string"/>

            <description jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Description"
                fieldDescription="Short product summary (max 300 characters)"
                name="description"
                required="{Boolean}true"
                renderType="textarea"
                valueType="string"/>

            <image jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/contentreference"
                fieldLabel="Product Image"
                fieldDescription="Product photo from /content/dam/4teradyne/products"
                name="image"
                required="{Boolean}false"
                renderType="contentreference"
                valueType="string"
                rootPath="/content/dam/4teradyne/products"/>

            <category jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/fragmentreference"
                fieldLabel="Product Category"
                fieldDescription="The primary product category"
                name="category"
                required="{Boolean}true"
                renderType="fragmentreference"
                valueType="string"
                fragmentModelPath="/conf/4teradyne/settings/dam/cfm/models/product-category"/>

            <searchWeight jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/numberfield"
                fieldLabel="Search Weight"
                fieldDescription="Sort priority (lower = higher priority)"
                name="searchWeight"
                required="{Boolean}false"
                renderType="numberfield"
                valueType="long"
                defaultValue="10"/>

            <brochureLabel jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Brochure Button Label"
                fieldDescription="CTA button text"
                name="brochureLabel"
                required="{Boolean}false"
                renderType="textfield"
                valueType="string"
                defaultValue="Learn More"/>

            <brochureUrl jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Brochure URL"
                fieldDescription="Link to product brochure PDF or landing page"
                name="brochureUrl"
                required="{Boolean}false"
                renderType="textfield"
                valueType="string"/>

            <brochureTarget jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/enumeration"
                fieldLabel="Brochure Link Target"
                fieldDescription="Whether brochure opens in new tab"
                name="brochureTarget"
                required="{Boolean}false"
                renderType="dropdown"
                valueType="string"
                defaultValue="_blank"
                emptyOption="{Boolean}false">
                <items jcr:primaryType="nt:unstructured">
                    <item0 jcr:primaryType="nt:unstructured" value="_self" label="Same Window"/>
                    <item1 jcr:primaryType="nt:unstructured" value="_blank" label="New Tab"/>
                </items>
            </brochureTarget>

            <platformFilter jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/enumeration"
                fieldLabel="Platform"
                fieldDescription="Hardware platform form factors"
                name="platformFilter"
                required="{Boolean}false"
                renderType="checkbox"
                valueType="string[]"
                emptyOption="{Boolean}false">
                <items jcr:primaryType="nt:unstructured">
                    <pxi jcr:primaryType="nt:unstructured" value="PXI" label="PXI"/>
                    <pxie jcr:primaryType="nt:unstructured" value="PXIe" label="PXIe"/>
                    <lxi jcr:primaryType="nt:unstructured" value="LXI" label="LXI"/>
                    <vxi jcr:primaryType="nt:unstructured" value="VXI" label="VXI"/>
                </items>
            </platformFilter>

            <physicalInterfaceFilter jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/enumeration"
                fieldLabel="Physical Interface"
                fieldDescription="Connection types"
                name="physicalInterfaceFilter"
                required="{Boolean}false"
                renderType="checkbox"
                valueType="string[]"
                emptyOption="{Boolean}false">
                <items jcr:primaryType="nt:unstructured">
                    <copper jcr:primaryType="nt:unstructured" value="Copper" label="Copper"/>
                    <optical jcr:primaryType="nt:unstructured" value="Optical" label="Optical"/>
                </items>
            </physicalInterfaceFilter>

            <swDefinedFilter jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/boolean"
                fieldLabel="Software-Defined"
                fieldDescription="Whether the instrument is software-defined"
                name="swDefinedFilter"
                required="{Boolean}false"
                renderType="boolean"
                valueType="boolean"/>

            <ceFilter jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/boolean"
                fieldLabel="CE Certified"
                fieldDescription="CE compliance flag"
                name="ceFilter"
                required="{Boolean}false"
                renderType="boolean"
                valueType="boolean"/>

            <supportedBusFilter jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Supported Bus Protocols"
                fieldDescription="Comma-separated bus protocols (e.g., Ethernet, Fibre Channel, MIL-STD-1553)"
                name="supportedBusFilter"
                required="{Boolean}false"
                renderType="textfield"
                multi="{Boolean}true"
                valueType="string[]"/>

            <testApplicationsFilter jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Test Applications"
                fieldDescription="Test application scenarios this product supports"
                name="testApplicationsFilter"
                required="{Boolean}false"
                renderType="textfield"
                multi="{Boolean}true"
                valueType="string[]"/>

            <numberOfChannelsFilter jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Number of Channels"
                fieldDescription="Channel counts (e.g., 2, 4, 8, 16)"
                name="numberOfChannelsFilter"
                required="{Boolean}false"
                renderType="textfield"
                multi="{Boolean}true"
                valueType="string[]"/>

            <functionFilter jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Instrument Function"
                fieldDescription="Instrument function type (Analog Test category only)"
                name="functionFilter"
                required="{Boolean}false"
                renderType="textfield"
                multi="{Boolean}true"
                valueType="string[]"/>

            <resolutionFilter jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Resolution"
                fieldDescription="ADC/DAC resolution (Analog Test only)"
                name="resolutionFilter"
                required="{Boolean}false"
                renderType="textfield"
                multi="{Boolean}true"
                valueType="string[]"/>

            <analogBandwidthFilter jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Analog Bandwidth"
                fieldDescription="Analog bandwidth (Analog Test only)"
                name="analogBandwidthFilter"
                required="{Boolean}false"
                renderType="textfield"
                multi="{Boolean}true"
                valueType="string[]"/>

            <sampleRateFilter jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Maximum Sample Rate"
                fieldDescription="Maximum sample rate (Analog Test only)"
                name="sampleRateFilter"
                required="{Boolean}false"
                renderType="textfield"
                multi="{Boolean}true"
                valueType="string[]"/>

            <supportedBusDetails jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/fragmentreference"
                fieldLabel="Supported Bus Details"
                fieldDescription="Rich popup details for supported bus entries"
                name="supportedBusDetails"
                required="{Boolean}false"
                renderType="fragmentreference-multiple"
                valueType="string[]"
                fragmentModelPath="/conf/4teradyne/settings/dam/cfm/models/product-popup-detail"/>

            <testApplicationDetails jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/fragmentreference"
                fieldLabel="Test Application Details"
                fieldDescription="Rich popup details for test application entries"
                name="testApplicationDetails"
                required="{Boolean}false"
                renderType="fragmentreference-multiple"
                valueType="string[]"
                fragmentModelPath="/conf/4teradyne/settings/dam/cfm/models/product-popup-detail"/>

        </items>
    </jcr:content>
</jcr:root>
