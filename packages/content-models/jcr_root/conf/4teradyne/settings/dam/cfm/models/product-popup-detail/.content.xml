<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="cq:Template"
          jcr:title="Product Popup Detail"
          jcr:description="Rich popup content for supported bus or test application entries"
          ranking="{Long}300"
          status="enabled">
    <jcr:content
        jcr:primaryType="nt:unstructured"
        jcr:title="Product Popup Detail"
        dataTypesConfig="/mnt/overlay/settings/dam/cfm/models/formbuilderconfig/datatypes"
        formModelPath="dam/cfm/models/editor/components/aemform">
        <items jcr:primaryType="nt:unstructured">

            <heading jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Heading"
                fieldDescription="Popup heading (e.g., Data-Intensive Testing)"
                name="heading"
                required="{Boolean}true"
                renderType="textfield"
                valueType="string"/>

            <details jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Details"
                fieldDescription="Detailed description of the capability"
                name="details"
                required="{Boolean}false"
                renderType="textarea"
                valueType="string"/>

            <relatedInstrumentsHeading jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Related Instruments Heading"
                fieldDescription="Subheading for related instruments section"
                name="relatedInstrumentsHeading"
                required="{Boolean}false"
                renderType="textfield"
                valueType="string"
                defaultValue="Related Instruments"/>

            <relatedInstruments jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="Related Instruments"
                fieldDescription="Comma-separated list of related instrument names"
                name="relatedInstruments"
                required="{Boolean}false"
                renderType="textfield"
                multi="{Boolean}true"
                valueType="string[]"/>

            <ctaLabel jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="CTA Button Label"
                fieldDescription="Call-to-action button text"
                name="ctaLabel"
                required="{Boolean}false"
                renderType="textfield"
                valueType="string"/>

            <ctaUrl jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/textfield"
                fieldLabel="CTA Button URL"
                fieldDescription="Call-to-action button link"
                name="ctaUrl"
                required="{Boolean}false"
                renderType="textfield"
                valueType="string"/>

            <image jcr:primaryType="nt:unstructured"
                cfm-element=""
                sling:resourceType="dam/cfm/models/editor/components/contentreference"
                fieldLabel="Popup Image"
                fieldDescription="Optional image for the popup"
                name="image"
                required="{Boolean}false"
                renderType="contentreference"
                valueType="string"
                rootPath="/content/dam/4teradyne/defense-aerospace/product-explorer"/>

        </items>
    </jcr:content>
</jcr:root>
